# Jira
JIRA_BASE_URL=https://mamtavenugopal.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_ENABLED=true
JIRA_REQUIRED=false
JIRA_PROJECT_KEY=AEA
JIRA_ISSUE_TYPE=Task
# Optional Service Desk project (omit to skip SD ticket)
# JIRA_SD_PROJECT_KEY=SD
# JIRA_SD_ISSUE_TYPE=Task

# GitHub — PySpark pipelines repo (this repo)
GITHUB_TOKEN=ghp_your_github_pat
GITHUB_REPO=MamtaVenugopal/etl-spark-entry
GITHUB_BASE_BRANCH=main
GITHUB_MERGE_METHOD=squash
GITHUB_DELETE_BRANCH_AFTER_MERGE=true

# Human gates (false) vs auto when agent evaluations pass (true)
AUTO_GATE_1=true
AUTO_GATE_2=true

# === AWS data platform (Agent 1 RAG + Agents 2–4) ===
DATA_PLATFORM=aws
SCHEMA_BACKEND=aws
AWS_REGION=us-west-1
# AWS_PROFILE=your-profile
S3_DATA_BUCKET=olist-ecommerce-raw-2026
S3_BRONZE_PREFIX=bronze/raw
S3_GOLD_PREFIX=gold
ATHENA_OUTPUT_S3=s3://olist-ecommerce-raw-2026/athena-results/
GLUE_DATABASE_BRONZE=bronze
GLUE_DATABASE_GOLD=gold
GLUE_TABLE_PREFIX=olist
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_S3=s3://your-olist-etl-bucket/athena-results/
# MWAA_ENV_NAME=etl-capstone

# Legacy Databricks (only if DATA_PLATFORM=databricks)
# Databricks (workspace root only — no /explore/ path)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_pat
DATABRICKS_DASHBOARD_URL=https://your-workspace.cloud.databricks.com/sql/dashboards/...

# Agent 3 — run PySpark pipeline on cluster (Phase A)
DATABRICKS_CLUSTER_ID=your-interactive-or-job-cluster-id
# DATABRICKS_PIPELINE_JOB_ID=123456
# DATABRICKS_WORKSPACE_DIR=/Workspace/etl-agent/pipelines
# DATABRICKS_JOB_POLL_SEC=15
# DATABRICKS_JOB_TIMEOUT_SEC=3600
# TESTS_LOCAL_PYTEST_ONLY=false

# Agent 3 Phase B + Agent 5 — SQL warehouse
DATABRICKS_SERVER_HOSTNAME=dbc-xxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
DATABRICKS_ACCESS_TOKEN=dapi...
DATABRICKS_CATALOG=olist_ecommerce
DATABRICKS_AUDIT_TABLE=gold.etl_run_reports

# OpenAI (Agent 1 Task Breakdown + optional LLM evaluation)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# Set true to add LLM critique on top of rule-based spec checks
EVAL_USE_LLM=false

# Agent 1 — RAG schema validation (FAISS + schema_chunks.json)
SCHEMA_RAG_ENABLED=true
SCHEMA_RAG_TOP_K=6
# SCHEMA_CHUNKS_PATH=data/olist_schema/schema_chunks.json
# SCHEMA_INDEX_PATH=data/olist_schema/faiss_index
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SCHEMA_INDEX_MAX_AGE_DAYS=10
SCHEMA_AUTO_REFRESH=true
SCHEMA_POLL_ON_STORY=true
# Secret for POST /schema/refresh (Databricks notebook calls this after bronze load)
SCHEMA_WEBHOOK_SECRET=change-me-in-production
# Databricks sync: DATABRICKS_SQL_WAREHOUSE_ID, DATABRICKS_CATALOG, DATABRICKS_SCHEMA, DATABRICKS_TABLE_PREFIX=olist

# Redis queue
REDIS_URL=redis://localhost:6379/0

# API / CORS (comma-separated origins for landing UI)
ALLOWED_ORIGINS=https://etl-spark-entry-qutk.vercel.app,http://localhost:5173,http://localhost:5174

# Worker timing (seconds)
WORKER_STEP_SLEEP_SEC=2
WORKER_GATE_POLL_SEC=1
